# ============================================================
# OPENAI — chave da API (platform.openai.com)
# ============================================================
OPENAI_API_KEY=sk-...

# ============================================================
# GOOGLE CALENDAR
# Obtenha em: console.cloud.google.com → Credenciais → OAuth 2.0
# ============================================================
GOOGLE_CLIENT_ID=SEU_CLIENT_ID_AQUI.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=SEU_CLIENT_SECRET_AQUI

# Token gerado pelo script auth-google.js (JSON em uma única linha)
GOOGLE_TOKEN={"access_token":"...","refresh_token":"...","token_type":"Bearer","expiry_date":...}

# ============================================================
# TRELLO
# ============================================================
TRELLO_API_KEY=SUA_TRELLO_API_KEY_AQUI
TRELLO_TOKEN=SEU_TRELLO_TOKEN_AQUI
TRELLO_BOARD_ID=SEU_TRELLO_BOARD_ID_AQUI

# ============================================================
# CONFIGURAÇÕES GERAIS
# ============================================================
TIMEZONE=America/Sao_Paulo
PORT=3000
